{
  "design_root": "[기획서]",
  "enforce_top_level_design_root": true,
  "active_roots": [
    "[기획서]",
    "skills"
  ],
  "ignored_segments": [
    "archive",
    "[백업]",
    "[보류]",
    "[제거 후보]",
    "hold",
    "deprecated"
  ],
  "required_paths": [
    "AGENTS.md",
    "tools/build_project_skill_map.py",
    "tools/skill_map_diagrams.py",
    "[기획서]/00_프로젝트_허브/START_HERE.md",
    "[기획서]/00_프로젝트_허브/ACTIVE_CONTEXT.md",
    "[기획서]/00_프로젝트_허브/DOCUMENTATION_MAP.md",
    "[기획서]/00_프로젝트_허브/DOCUMENT_UPDATE_MATRIX.md",
    "[기획서]/00_프로젝트_허브/DEVELOPMENT_GATES.md",
    "[기획서]/00_프로젝트_허브/SKILL_REGISTRY.json",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.docx",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.pdf",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.assets",
    "[기획서]/00_프로젝트_허브/SKILL_MAP_PUBLICATION_MANIFEST.json",
    "[기획서]/00_프로젝트_허브/AI_WORKFLOW.md",
    "[기획서]/00_프로젝트_허브/PUBLICATION_MANIFEST.json",
    "skills/foundation"
  ],
  "forbidden_active_name_patterns": [
    "(?i)(^|[_-])(v[0-9]+|final|latest|copy|new)([_-]|\\.)"
  ],
  "markdown_link_roots": [
    "[기획서]",
    "skills"
  ],
  "asset_manifests": [
    "[기획서]/06_아트/ASSET_MANIFEST.yml"
  ],
  "publication_manifest": "[기획서]/00_프로젝트_허브/PUBLICATION_MANIFEST.json",
  "enforce_publications": false,
  "skill_registry": "[기획서]/00_프로젝트_허브/SKILL_REGISTRY.json",
  "enforce_skill_registry": true,
  "skill_map_publication_manifest": "[기획서]/00_프로젝트_허브/SKILL_MAP_PUBLICATION_MANIFEST.json",
  "enforce_skill_map_publication": true,
  "require_human_skill_map_visual_review": false,
  "forbidden_markdown_skill_map": "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.md",
  "skill_map_sync_paths": [
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.docx",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.pdf",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.assets/skill-flow.png",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.assets/discipline-routing.png",
    "[기획서]/00_프로젝트_허브/PROJECT_SKILL_MAP.assets/skill-matrix.png",
    "[기획서]/00_프로젝트_허브/SKILL_MAP_PUBLICATION_MANIFEST.json"
  ],
  "skill_map_generator_globs": [
    "tools/build_project_skill_map.py",
    "tools/skill_map_diagrams.py"
  ],
  "required_skill_disciplines": [
    "설정·내러티브",
    "게임 디자인",
    "UX·UI·접근성",
    "개발·엔지니어링",
    "테크니컬 아트·파이프라인",
    "아트",
    "사운드",
    "QA",
    "프로덕션·PM",
    "분석·유저리서치",
    "통합검수"
  ],
  "skill_change_globs": [
    "skills/**/SKILL.md"
  ],
  "learning_log_globs": [
    "skills/**/LEARNING_LOG.md",
    "skills/**/SKILL_LEARNING_LOG.md"
  ],
  "change_rules": [
    {
      "name": "gameplay-or-data-change",
      "source_globs": ["scripts/**", "scenes/**", "data/**", "resources/**"],
      "required_any": [
        "[기획서]/02_게임_디자인/게임_기획서.md",
        "[기획서]/04_개발_엔지니어링/개발_기획서.md"
      ],
      "required_all": ["[기획서]/00_프로젝트_허브/ACTIVE_CONTEXT.md"]
    },
    {
      "name": "visual-asset-change",
      "source_globs": ["assets/**", "art/**", "images/**"],
      "required_any": [
        "[기획서]/05_테크니컬아트_파이프라인/테크니컬아트_기획서.md",
        "[기획서]/06_아트/아트_기획서.md"
      ],
      "required_all": ["[기획서]/06_아트/ASSET_MANIFEST.yml"]
    },
    {
      "name": "audio-change",
      "source_globs": ["audio/**", "sound/**", "music/**"],
      "required_any": ["[기획서]/07_사운드/사운드_기획서.md"],
      "required_all": ["[기획서]/00_프로젝트_허브/ACTIVE_CONTEXT.md"]
    },
    {
      "name": "responsibility-path-change",
      "source_globs": [
        "AGENTS.md",
        "[기획서]/**/README.md",
        "[기획서]/**/START_HERE.md",
        "[기획서]/**/DOCUMENTATION_MAP.md",
        "skills/**/SKILL.md"
      ],
      "required_any": [],
      "required_all": [
        "[기획서]/00_프로젝트_허브/DOCUMENTATION_MAP.md",
        "[기획서]/00_프로젝트_허브/SKILL_REGISTRY.json",
        "[기획서]/00_프로젝트_허브/SKILL_MAP_PUBLICATION_MANIFEST.json"
      ]
    },
    {
      "name": "development-gate-change",
      "source_globs": [
        "[기획서]/00_프로젝트_허브/DEVELOPMENT_GATES.md",
        "[기획서]/09_프로덕션_PM/**",
        "[기획서]/11_통합검수/**"
      ],
      "required_any": [],
      "required_all": ["[기획서]/00_프로젝트_허브/ACTIVE_CONTEXT.md"]
    },
    {
      "name": "publication-policy-change",
      "source_globs": [
        "tools/build_discipline_publications.py",
        "[기획서]/00_프로젝트_허브/PUBLICATION_MANIFEST.json"
      ],
      "required_any": [],
      "required_all": ["[기획서]/00_프로젝트_허브/AI_WORKFLOW.md"]
    }
  ]
}
