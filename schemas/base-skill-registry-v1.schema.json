{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alsdmlals4-eng/Base/schemas/base-skill-registry-v1.schema.json",
  "title": "Base Shared Skill Registry v1",
  "type": "object",
  "required": ["schema_version", "registry_role", "routing_policy", "skills"],
  "properties": {
    "schema_version": {"const": 1},
    "registry_role": {"const": "base-shared-skill-router"},
    "routing_policy": {
      "type": "object",
      "required": [
        "load_all_skills",
        "default_selection",
        "automatic_selection",
        "user_skill_declaration_required",
        "require_trigger_match",
        "require_execution_report",
        "work_modes",
        "max_primary_discipline_skills",
        "max_foundation_skills",
        "exclude_statuses"
      ],
      "properties": {
        "load_all_skills": {"const": false},
        "default_selection": {"const": "automatic-trigger-match"},
        "automatic_selection": {"const": true},
        "user_skill_declaration_required": {"const": false},
        "require_trigger_match": {"const": true},
        "require_execution_report": {"const": true},
        "work_modes": {
          "type": "array",
          "const": ["PLAN", "BUILD", "REVIEW"]
        },
        "max_primary_discipline_skills": {"type": "integer", "minimum": 1},
        "max_foundation_skills": {"type": "integer", "minimum": 1},
        "exclude_statuses": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["skill_id", "layer", "discipline", "path", "status", "load_by_default", "trigger_tags", "use_when", "do_not_use_when", "learning_log", "review_triggers", "last_reviewed_at", "last_reviewed_commit", "knowledge_state"],
        "properties": {
          "skill_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "layer": {"enum": ["foundation", "specialist"]},
          "discipline": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^skills/.+/SKILL\\.md$"},
          "status": {"enum": ["ACTIVE", "HOLD", "BACKUP", "REMOVAL_CANDIDATE"]},
          "load_by_default": {"const": false},
          "trigger_tags": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "use_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "do_not_use_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "learning_log": {"type": "string", "minLength": 1},
          "review_triggers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "last_reviewed_at": {"type": "string", "format": "date"},
          "last_reviewed_commit": {"type": "string", "minLength": 7},
          "knowledge_state": {"enum": ["OBSERVATION", "HYPOTHESIS", "PATTERN", "VERIFIED", "PROMOTION_CANDIDATE"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
